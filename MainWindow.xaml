<Window x:Class="Student_Form.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Student_Form"
        mc:Ignorable="d"
        Title="Student Form" Height="450" Width="800" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

   

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="5"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
        </Grid.RowDefinitions>
        
        <!--#region TITLE-->
        <Label Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
               FontStyle="Normal" FontWeight="Bold"
               HorizontalContentAlignment="Center"
               FontSize="26"
               Content="STUDENT INFORMATION" FontFamily="Bahnschrift"/>
        <Separator Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" />
        <!--#endregion-->
        
        <!--#region STUDENT TABLE-->
        <StackPanel Grid.Row="3" Grid.Column="1"
                    Orientation="Vertical"
                    x:Name="panelStudentTable">
            <DataGrid x:Name="dataGrid" Height="300"
                      AutoGenerateColumns="False"
                      SelectionChanged="dataGrid_SelectionChanged"
                      FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Firstname"
                            Binding="{Binding Firstname}" />
                    <DataGridTextColumn Header="Address"
                            Binding="{Binding Address}" />
                    <DataGridTextColumn Header="Program"
                            Binding="{Binding Program}" />
                    <DataGridTextColumn Header="Year Level"
                            Binding="{Binding YearLevel}" />
                </DataGrid.Columns>
            </DataGrid>
            <Button x:Name="btnDeleteData" Content="DELETE DATA"
                    Height="50" FontSize="20"
                    FontWeight="Bold"
                    Margin="0,5"
                    IsEnabled="False"
                    Click="btnDeleteData_Click"
                    Background="Beige"
                    />
        </StackPanel>
        <!--#endregion-->
        
        <!--#region STUDENT TABLE-->
        <Grid Grid.Row="3" Grid.Column="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="30"/>                  
                <RowDefinition Height="50"/>                  
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!--Form Title-->
            <Label Grid.Row="0"
                   Grid.Column="1"                                      Content="Student Details"
                   FontWeight="DemiBold"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   FontSize="13" />
            <Label Grid.Row="2"
                   Grid.Column="1"
                   Content="Fullname"
                   FontSize="11"
                   Padding="1"
                   FontWeight="DemiBold" />
            <TextBox Grid.Row="3"
                     x:Name="txtFullname"
                     Grid.Column="1" 
                     HorizontalContentAlignment="Right"
                     FontSize="14"
                     BorderThickness="0,0,0,1"
                     Padding="2" />
            <Label Grid.Row="5"
                   Grid.Column="1"
                   Content="Address"
                   FontSize="11"
                   Padding="1"
                   FontWeight="DemiBold" />
            <TextBox Grid.Row="6"
                     x:Name="txtAddress"
                     Grid.Column="1" 
                     HorizontalContentAlignment="Right"
                     FontSize="14"
                     BorderThickness="0,0,0,1"
                     Padding="2" />
            <Label Grid.Row="8"
                   Grid.Column="1"
                   Content="Program"
                   FontSize="11"
                   Padding="1"
                   FontWeight="DemiBold" />

            <ComboBox x:Name="comboBoxProgram"
                      Grid.Row="9"
                      Grid.Column="1"
                      BorderThickness="0">
                <ComboBoxItem Content="BS in Information Technology"/>
                <ComboBoxItem Content="BS in Business Administration"/>
                <ComboBoxItem Content="BS in Criminology"/>
                <ComboBoxItem Content="BS in Tourism Management"/>
                <ComboBoxItem Content="BS in Hospitality Management"/>
            </ComboBox>
            <Label Grid.Row="11"
                   Grid.Column="1"
                   Content="Year Level"
                   FontSize="11"
                   Padding="1"
                   FontWeight="DemiBold" />
            <!--Year Level radio button -->
            <StackPanel Grid.Row="12" Grid.Column="1"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <RadioButton x:Name="rbOne" Content="1" GroupName="YearLevel" Margin="10,0"/>
                <RadioButton x:Name="rbTwo" Content="2" GroupName="YearLevel" Margin="10,0"/>
                <RadioButton x:Name="rbThree" Content="3" GroupName="YearLevel" Margin="10,0"/>
                <RadioButton x:Name="rbFour" Content="4" GroupName="YearLevel" Margin="10,0"/>
            </StackPanel>
            <Button x:Name="btnSave" 
                    Grid.Column="1" Grid.Row="13"
                    Content="SAVE" FontSize="20"
                    Click="btnSave_Click"
                    FontWeight="Bold"
                    Margin="0,5"                  
                    Background="Beige"/>

        </Grid>
    </Grid>
    
</Window>
